// 1. Prisma Configuration
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// 2. Enums - Strong typed dictionaries
enum ReactionType {
  LIKE    
  LOVE    
  HAHA    
  SAD     
  ANGRY   
}

enum NotifType {
  NEW_COMMENT
  NEW_REACTION
  FRIEND_REQUEST
  MESSAGE
}

// 3. Database Models

model User {
  id              String     @id @default(uuid()) // Unique ID using UUID for security
  firstName       String
  lastName        String
  username        String     @unique
  email           String     @unique
  password        String     // Hashed password (bcrypt)
  dateOfBirth     DateTime
  acceptedTerms   Boolean    // GDPR compliance
  avatarUrl       String?    // Optional profile picture
  
  // Relations
  posts           Post[]
  comments        Comment[]
  reactions       Reaction[]
  
  // Friends System (Self-relation many-to-many)
  friendships     Friendship[] @relation("UserFriendships")
  friendOf        Friendship[] @relation("FriendOfUser")
  
  // Notifications System
  notifsReceived  Notification[] @relation("NotifReceiver")
  notifsSent      Notification[] @relation("NotifActor")
  
  // Chat & Groups
  messages        Message[]
  conversations   ConversationParticipant[]
  groupMembers    GroupMember[]

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

model Post {
  id          String     @id @default(uuid())
  content     String?    @db.Text // Long text content support
  imageUrl    String?    // URL to the uploaded image
  
  authorId    String
  author      User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  
  groupId     String?    // Optional: if post belongs to a group
  group       Group?     @relation(fields: [groupId], references: [id], onDelete: Cascade)

  comments    Comment[]
  reactions   Reaction[]
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Comment {
  id          String     @id @default(uuid())
  content     String     @db.Text
  
  postId      String
  post        Post       @relation(fields: [postId], references: [id], onDelete: Cascade)
  
  authorId    String
  author      User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  
  reactions   Reaction[] // Reactions for the comment itself

  createdAt   DateTime   @default(now())
}

model Reaction {
  id          String       @id @default(uuid())
  type        ReactionType
  
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  postId      String?      // Reaction to a post
  post        Post?        @relation(fields: [postId], references: [id], onDelete: Cascade)
  
  commentId   String?      // Reaction to a comment
  comment     Comment?     @relation(fields: [commentId], references: [id], onDelete: Cascade)

  createdAt   DateTime     @default(now())
}

model Friendship {
  id          String   @id @default(uuid())
  status      String   @default("PENDING") // PENDING, ACCEPTED, BLOCKED
  
  requesterId String
  requester   User     @relation("UserFriendships", fields: [requesterId], references: [id], onDelete: Cascade)
  
  addresseeId String
  addressee   User     @relation("FriendOfUser", fields: [addresseeId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
}

model Notification {
  id          String    @id @default(uuid())
  type        NotifType
  isRead      Boolean   @default(false)
  
  receiverId  String
  receiver    User      @relation("NotifReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  
  actorId     String
  actor       User      @relation("NotifActor", fields: [actorId], references: [id], onDelete: Cascade)
  
  postId      String?
  commentId   String?

  createdAt   DateTime  @default(now())
}

// --- CHAT & GROUPS SYSTEM ---

model Group {
  id          String        @id @default(uuid())
  name        String
  description String?       @db.Text
  coverUrl    String?
  
  creatorId   String
  
  members     GroupMember[]
  posts       Post[]

  createdAt   DateTime      @default(now())
}

model GroupMember {
  id        String   @id @default(uuid())
  role      String   @default("MEMBER") // ADMIN, MODERATOR, MEMBER
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  groupId   String
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)

  joinedAt  DateTime @default(now())
}

model Conversation {
  id           String                    @id @default(uuid())
  isGroupChat  Boolean                   @default(false)
  name         String?                   // Used for group chat names
  
  participants ConversationParticipant[]
  messages     Message[]

  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
}

model ConversationParticipant {
  id             String       @id @default(uuid())
  
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  joinedAt       DateTime     @default(now())
}

model Message {
  id             String       @id @default(uuid())
  content        String       @db.Text
  
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  createdAt      DateTime     @default(now())
}